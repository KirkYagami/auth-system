# ── Version control ───────────────────────────────────────────────────────────
.git/
.gitignore

# ── Environment & secrets ─────────────────────────────────────────────────────
.env
*.env
.env.*

# ── Python cache & build artifacts ───────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg-info/
dist/
build/
.eggs/
*.so

# ── Virtual environments ──────────────────────────────────────────────────────
venv/
.venv/
env/
ENV/

# ── IDE & editor files ────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# ── Test & coverage artifacts ─────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/
.ruff_cache/

# ── Documentation (not needed at runtime) ────────────────────────────────────
*.md
docs/

# ── Docker files themselves ───────────────────────────────────────────────────
Dockerfile
Dockerfile.*
docker-compose*.yml
.dockerignore

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
logs/
